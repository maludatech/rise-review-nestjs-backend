generator client {
  provider     = "prisma-client"
  output       = "../src/generated/internal"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum LeadAction {
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  CLICKED_LINK
  UNSUBSCRIBED
  FOLLOW_UP_SENT
}

model Admin {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  Leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Lead {
  id Int @id @default(autoincrement())

  businessName String
  email        String
  city         String
  industry     String?

  createdById Int
  createdBy   Admin @relation(fields: [createdById], references: [id])

  googleRating Float?
  reviewCount  Int?
  googlePlaceId String?

  isEnriched Boolean @default(false)

  emailSent Boolean @default(false)
  sentAt    DateTime?

  opened    Boolean @default(false)
  openedAt  DateTime?

  replied Boolean @default(false)

  resendCount Int @default(0)

  unsubscribeToken String?
  unsubscribed     Boolean @default(false)

  source String @default("csv")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  histories LeadHistory[]

  @@index([googlePlaceId])
}

model LeadHistory {
  id Int @id @default(autoincrement())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  action LeadAction

  metadata Json?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([action])
  @@index([createdAt])
}